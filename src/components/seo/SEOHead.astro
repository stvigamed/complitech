---
import { locales, ogLocales, type Locale } from '../../i18n/config';
import { getMeta } from '../../i18n/ui';

interface Props {
  locale: Locale;
  path?: string;
  title?: string;
  description?: string;
  noindex?: boolean;
}

const { locale, path = '/', title, description, noindex = false } = Astro.props;
const meta = getMeta(locale);
const pageTitle = title ?? meta.title;
const pageDescription = description ?? meta.description;
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://complitech.ee';

const localePath = locale === 'en' ? '/' : `/${locale}/`;
const canonical = new URL(localePath, site).toString();
const ogImage = new URL('/images/logo-big.webp', site).toString();
---

<title>{pageTitle}</title>
<meta name="description" content={pageDescription} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonical} />

<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="Compli Tech OÜ" />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={ogLocales[locale]} />

{
  locales
    .filter((l) => l !== locale)
    .map((l) => <meta property="og:locale:alternate" content={ogLocales[l]} />)
}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDescription} />
<meta name="twitter:image" content={ogImage} />

{
  locales.map((l) => {
    const href = l === 'en' ? `${site}/` : `${site}/${l}/`;
    return <link rel="alternate" hreflang={l} href={href} />;
  })
}
<link rel="alternate" hreflang="x-default" href={`${site}/`} />

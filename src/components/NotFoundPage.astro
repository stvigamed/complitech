---
import { getRelativeLocaleUrl } from 'astro:i18n';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { useTranslations } from '../i18n/ui';
import { locales } from '../i18n/config';

const localeContent = locales.map((locale) => {
  const { t } = useTranslations(locale);
  return {
    locale,
    t,
    homeUrl: getRelativeLocaleUrl(locale, '/'),
  };
});
---

<BaseLayout
  locale="en"
  title={useTranslations('en').t('notFound.title')}
  description={useTranslations('en').t('notFound.description')}
  noindex
>
  <Fragment slot="head">
    <style is:inline>
      html:not([data-locale='ru']) .locale-ru {
        display: none;
      }

      html[data-locale='ru'] .locale-en {
        display: none;
      }
    </style>
    <script is:inline define:vars={{ ruTitle: useTranslations('ru').t('notFound.title') }}>
      if (location.pathname.startsWith('/ru')) {
        document.documentElement.lang = 'ru';
        document.documentElement.dataset.locale = 'ru';
        document.title = ruTitle;
      }
    </script>
  </Fragment>

  {
    localeContent.map(({ locale, t, homeUrl }) => (
      <div class={`locale-${locale} flex min-h-dvh flex-col`}>
        <Header locale={locale} />
        <main id={locale === 'en' ? 'main' : undefined} class="flex flex-1 flex-col">
          <section
            class="relative flex flex-1 items-center overflow-hidden bg-gradient-to-br from-navy via-navy-light to-teal px-4 py-20 sm:px-6 sm:py-28"
            aria-labelledby={`not-found-heading-${locale}`}
          >
            <div
              class="pointer-events-none absolute inset-0 opacity-10"
              aria-hidden="true"
              style="background-image: radial-gradient(circle at 20% 50%, white 1px, transparent 1px); background-size: 32px 32px;"
            />

            <div class="relative mx-auto w-full max-w-3xl text-center">
              <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-teal-light">404</p>
              <h1
                id={`not-found-heading-${locale}`}
                class="mb-4 text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl"
              >
                {t('notFound.heading')}
              </h1>
              <p class="mx-auto mb-8 max-w-xl text-base leading-relaxed text-white/85 sm:text-lg">
                {t('notFound.description')}
              </p>
              <a
                href={homeUrl}
                class="inline-flex items-center justify-center rounded-lg bg-teal px-6 py-3 text-sm font-semibold text-white shadow-lg transition-colors hover:bg-teal-light focus:outline-none focus:ring-2 focus:ring-teal-light focus:ring-offset-2 focus:ring-offset-navy"
              >
                {t('notFound.cta')}
              </a>
            </div>
          </section>
        </main>
        <Footer locale={locale} />
      </div>
    ))
  }
</BaseLayout>

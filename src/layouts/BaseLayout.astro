---
import '../styles/global.css';
import SEOHead from '../components/seo/SEOHead.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import type { Locale } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  noindex?: boolean;
}

const { locale, title, description, noindex } = Astro.props;
const { t } = useTranslations(locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <slot name="head" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/jpeg" href="/images/logo-small.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <SEOHead locale={locale} title={title} description={description} noindex={noindex} />
    <JsonLd locale={locale} />
  </head>
  <body class="antialiased">
    <a href="#main" class="skip-link">{t('nav.skip')}</a>
    <slot />
  </body>
</html>
